&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-Markdown&#34; data-lang=&#34;Markdown&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;#!/bin/bash
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;#重庆财经职业学院 校园网登录脚本
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;&lt;/span&gt;server=172.22.44.46    &lt;span class=&#34;ni&#34;&gt;#修改成你校校园网服务器IP&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;user=202400000000      &lt;span class=&#34;ni&#34;&gt;#修改成你的账号&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;password=&amp;#34;00000000&amp;#34;    &lt;span class=&#34;ni&#34;&gt;#修改成你的密码&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;wlanacname=&amp;#34;&amp;#34;  # 修改成你所连接的AP的名字,我的环境不需要
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;html_file=&amp;#34;/tmp/drcom_html.log&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;login_out_file=&amp;#34;/tmp/drcom_login.log&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;开始检测网络&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;# 1. 先 ping 认证服务器（判断是否在校园网环境）
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;&lt;/span&gt;if ! ping -c 2 -W 2 &amp;#34;$server&amp;#34; &amp;gt; /dev/null 2&amp;gt;&lt;span class=&#34;ni&#34;&gt;&amp;amp;1;&lt;/span&gt; then
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;无法 ping 通 $server，未连接到校园网，退出&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    echo &amp;#34;未连接到校园网，退出脚本&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    exit 0
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;fi
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;# 2. 再 ping 外网（判断是否已登录且网络正常）
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;&lt;/span&gt;if ping -c 1 -W 2 baidu.com &amp;gt; /dev/null 2&amp;gt;&lt;span class=&#34;ni&#34;&gt;&amp;amp;1;&lt;/span&gt; then
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;外网已通，无需登录&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    echo &amp;#34;外网已通，无需登录&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    exit 0
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;fi
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;网络受限，尝试登录&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;echo &amp;#34;网络受限，执行登录操作&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;# 3. 获取内网 IP
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;&lt;/span&gt;dev=$(ip -4 route get 1 | awk &amp;#39;{print $5; exit}&amp;#39;)
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;ip=$(ip -4 addr show dev &amp;#34;$dev&amp;#34; | grep -o &amp;#39;inet [0-9.]*&amp;#39; | awk &amp;#39;{print $2}&amp;#39;)
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;if [ -z &amp;#34;$ip&amp;#34; ]; then
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;无法获取内网IP&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    echo &amp;#34;无法获取内网IP&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    exit 1
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;fi
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;# 4. 访问认证页面确认未登录状态
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;gh&#34;&gt;&lt;/span&gt;curl -s &amp;#34;http://${server}&amp;#34; &amp;gt; ${html_file}
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;if grep -q &amp;#34;Dr.COMWebLoginID_0.htm&amp;#34; ${html_file}; then
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;未登录状态，开始登录&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    echo &amp;#34;未登录，开始登录&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    url=&amp;#34;http://${server}:801/eportal/portal/login?callback=dr1004&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;login_method=1&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;user_account=%2C0%2C${user}&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;user_password=${password}&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;wlan_user_ip=${ip}&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;wlan_user_ipv6=&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;wlan_user_mac=000000000000&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;wlan_ac_ip=&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;wlan_ac_name=${wlanacname}&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;jsVersion=4.2.1&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;terminal_type=1&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;lang=zh-cn&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;v=6528&lt;span class=&#34;err&#34;&gt;&amp;amp;&lt;/span&gt;lang=zh&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    curl -s &amp;#34;$url&amp;#34; -H &amp;#34;Referer: http://${server}/&amp;#34; &amp;gt; ${login_out_file}
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    if grep -q &amp;#39;&amp;#34;result&amp;#34;:1&amp;#39; ${login_out_file} || grep -q &amp;#39;&amp;#34;result&amp;#34;:&amp;#34;ok&amp;#34;&amp;#39; ${login_out_file}; then
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;        logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;登录成功&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;        echo &amp;#34;登录成功&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    else
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;        logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;登录失败&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;        echo &amp;#34;登录失败&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    fi
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;else
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;页面状态异常（可能已登录）但外网不通，尝试重新登录&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;    echo &amp;#34;页面状态异常，尝试重新登录&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;fi
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;logger -t &amp;#34;DrCOM&amp;#34; &amp;#34;登录检测完成&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;echo &amp;#34;登录检测完成&amp;#34;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;
&lt;/div&gt;
&lt;/div&gt;&lt;blockquote&gt;
&lt;p&gt;注意:部分校园网在认证成功后会立即跳转到百度等网站，导致开发者工具中的登录请求一闪而过，来不及抓包。
提供一个操作思路
以管理员身份打开记事本（右键记事本 → 以管理员身份运行）
打开 C:\Windows\System32\drivers\etc\hosts
在末尾添加一行：127.0.0.1 &lt;a class=&#34;link&#34; href=&#34;https://www.baidu.com&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;www.baidu.com&lt;/a&gt;
保存文件
抓包完成后，再次以管理员身份打开 hosts 文件，删除这一行并保存&lt;/p&gt;
&lt;/blockquote&gt;
&lt;h1 id=&#34;23-openwrt插件&#34;&gt;2.3 openwrt插件
&lt;/h1&gt;&lt;p&gt;插件地址如下，使用方法请看readme&lt;br&gt;
&lt;a class=&#34;link&#34; href=&#34;https://github.com/1v7w/openwrt-webdogcom&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;https://github.com/1v7w/openwrt-webdogcom&lt;/a&gt;&lt;br&gt;
&lt;a class=&#34;link&#34; href=&#34;https://github.com/1v7w/webdogcom&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;https://github.com/1v7w/webdogcom&lt;/a&gt;&lt;/p&gt;
</description>
